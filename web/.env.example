# =============================================================
# team22 — variables de entorno
# Copiar a `.env.local` y llenar.
# =============================================================

# --- Database -------------------------------------------------
# Local: docker-compose en root del repo (`docker compose up`)
# Prod : Supabase Postgres (Settings → Database → Connection string)
DATABASE_URL=postgresql://team22:team22@localhost:5432/team22

# --- Anthropic ------------------------------------------------
# La key del cliente; el proxy la usa para forwardear a upstream.
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com

# --- Embeddings (reglas NL + AI Suggestor) --------------------
EMBEDDING_PROVIDER=openai            # openai | voyage
OPENAI_API_KEY=sk-...
VOYAGE_API_KEY=                      # solo si EMBEDDING_PROVIDER=voyage

# --- Auth.js v5 + Google OAuth (solo /admin) -----------------
# Si GOOGLE_CLIENT_ID está vacío, el proxy cae al bypass de demo
# (cookie mock con ?demo=1). Apenas pegues los valores reales,
# el admin pasa a requerir login con Google.
# Sacar Client ID y Secret de https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: <AUTH_URL>/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
AUTH_SECRET=                         # openssl rand -base64 32
AUTH_URL=http://localhost:3000

# --- App ------------------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
DEMO_ORG_ID=demo                     # single-tenant hardcoded para hack
ArkivGate_PROXY_URL=http://localhost:8080 # local interceptor; en Vercel usar https://<railway-app>.up.railway.app

# --- x402 demo rail -------------------------------------------
# The playground always demonstrates the x402 challenge/signature loop.
# To require the same demo payment rail on the Python interceptor, set
# X402_DEMO_ENABLED=true in interceptor/.env.

# --- WalletConnect / Reown ------------------------------------
# Optional. Create a project at https://dashboard.reown.com.
# When present, the landing uses Reown AppKit WalletConnect on Arkiv Braga.
# When empty, the demo falls back to an injected browser wallet if available.
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=

# --- ArkivGate MVP --------------------------------------------
# Wallet used by backend to create Arkiv entities for audit evidence.
ARKIV_AGENT_PRIVATE_KEY=0x...
# Keep globally unique. Include this in every Arkiv entity and query.
ARKIV_PROJECT=arkivgate-leocagli-2026
# Optional explorer chain hint used in shared links.
ARKIV_CHAIN=braga

# --- AI Suggestor (post-hack) ---------------------------------
SUGGESTOR_MIN_EVENTS=200
SUGGESTOR_LOOKBACK_DAYS=3
