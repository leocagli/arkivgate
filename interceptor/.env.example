# =============================================================
# ArkivGate interceptor â€” environment variables
# Copy to .env and fill in.
# =============================================================

# Postgres shared with web/ (see root docker-compose.yml).
DATABASE_URL=postgresql+asyncpg://team22:team22@localhost:5432/team22

# Upstream Anthropic API.
ANTHROPIC_UPSTREAM_URL=https://api.anthropic.com

# API key dedicada al NL judge (Layer 3, Haiku 4.5). Si estÃ¡ vacÃ­a, NL queda
# deshabilitado y el proxy se comporta como v0.1 (regex + passthrough).
# Sacala de https://console.anthropic.com/settings/keys
ANTHROPIC_JUDGE_API_KEY=

# Single-tenant org for the hack (matches web/.env.local DEMO_ORG_ID).
DEFAULT_ORG_ID=demo

# Server bind.
HOST=0.0.0.0
PORT=8080

# Optional: if set, interceptor forwards normalized audit decisions to the
# web app internal endpoint so it can write PromptReview/PolicyDecision to Arkiv.
ARKIV_BRIDGE_URL=http://localhost:3000/api/internal/arkiv/interactions
ARKIV_BRIDGE_TOKEN=change-me

# Optional demo x402 gate for real agent runtime calls.
# When true, POST /cli/<token>/v1/messages returns 402 until the caller retries
# with PAYMENT-SIGNATURE for that exact resource. This is demo settlement only:
# no real funds move yet.
X402_DEMO_ENABLED=false

# Optional: static token for demo environments when the production device-flow
# database is not available. Requests to /cli/<DEMO_CLI_TOKEN>/v1/messages use
# built-in demo policies and still require x402 if X402_DEMO_ENABLED=true.
DEMO_CLI_TOKEN=
